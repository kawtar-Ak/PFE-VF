{
  "name": "frontend",
  "version": "1.0.0",
  "main": "index.js",
  "private": true,
  "scripts": {
    "start": "set \"EXPO_NO_CACHE=1\" && set \"EXPO_HOME=.expo\" && expo start --web --max-workers 0",
    "start:no-open": "set \"EXPO_NO_CACHE=1\" && set \"EXPO_HOME=.expo\" && set \"BROWSER=none\" && expo start --web --max-workers 0",
    "start:expo": "set \"EXPO_NO_CACHE=1\" && set \"EXPO_HOME=.expo\" && expo start --max-workers 0",
    "android": "set \"EXPO_NO_CACHE=1\" && set \"EXPO_HOME=.expo\" && expo start --android --max-workers 0",
    "ios": "set \"EXPO_NO_CACHE=1\" && set \"EXPO_HOME=.expo\" && expo start --ios --max-workers 0",
    "web": "set \"EXPO_NO_CACHE=1\" && set \"EXPO_HOME=.expo\" && expo start --web --max-workers 0",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@react-navigation/native-stack": "^7.3.3",
    "expo": "~54.0.33",
    "expo-auth-session": "~7.0.10",
    "expo-crypto": "~15.0.8",
    "expo-random": "^14.0.1",
    "expo-splash-screen": "~31.0.13",
    "expo-web-browser": "~15.0.10",
    "node-fetch": "^3.3.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2"
  }
}
